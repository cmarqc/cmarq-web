# Copy this file to `.env` and fill in the values. `.env` is gitignored.

# ── Photography likes/views API (MySQL) ─────────────────────────────────────
# Hostinger hPanel → Databases → MySQL Databases. DB_HOST looks like
# srvXXXX.hstgr.io (not "localhost" unless the app runs on Hostinger itself).
# Also add your IP under Databases → Remote MySQL, or connections are refused.
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=

# ── Instagram aggregation (optional) ────────────────────────────────────────
# Leave empty to disable the "likes on Instagram" figures.
INSTAGRAM_ACCESS_TOKEN=

# ── Twitch live badge (optional) ────────────────────────────────────────────
# Register an app at https://dev.twitch.tv/console/apps. Leave empty to disable.
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
# Dev-only: 1 forces the live badge on for previewing. Ignored in production.
TWITCH_MOCK_LIVE=

# ── Photography storefront (Stripe + Cloudflare R2) ─────────────────────────
# "true" shows Purchase buttons and enables checkout; anything else hides the store.
NEXT_PUBLIC_STORE_ENABLED=false
# Absolute base URL used to build Stripe success/cancel links.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Stripe → Developers → API keys (sk_test_… while testing, sk_live_… in prod).
STRIPE_SECRET_KEY=
# Signing secret for /api/stripe/webhook (from the webhook config or `stripe listen`).
STRIPE_WEBHOOK_SECRET=

# Cloudflare R2 bucket holding the private full-resolution originals.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=cmarq-originals
# Minutes a presigned download link stays valid.
R2_URL_TTL_MINUTES=15

# Resend transactional email (optional — buyers still get on-page downloads without it).
# Verify a sending domain in Resend and create an API key.
RESEND_API_KEY=
# From address on a Resend-verified domain, e.g. "Christian Calloway <downloads@your-domain.com>".
EMAIL_FROM=
# Optional Reply-To so buyer replies reach your inbox.
EMAIL_REPLY_TO=
