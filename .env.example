# MySQL — required for the photography likes/views API.
# On Hostinger: create a database in hPanel → Databases → MySQL Databases,
# then copy the credentials here / into the Node.js app's environment variables.
DB_HOST=localhost
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=

# Optional — aggregates Instagram likes from @cmc.snaps into photo stats.
# Long-lived access token for an Instagram Professional account
# (Instagram API with Instagram Login). Leave empty to disable.
INSTAGRAM_ACCESS_TOKEN=
